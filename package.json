{
  "name": "curlyellie",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --bundle --format=esm --outfile=dist/index.js --minify --external:mysql2 --external:express && mkdir -p dist/public && mv dist/assets dist/index.html dist/public/",
    "start": "NODE_ENV=production node dist/index.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@trpc/client": "^11.9.0",
    "@trpc/react-query": "^11.9.0",
    "@trpc/server": "^11.9.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.2",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.3",
    "nanoid": "^5.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stripe": "^20.3.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1"
  }
}
